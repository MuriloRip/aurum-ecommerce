<!-- ======== MARQUEE BANNER ======== -->
<div class="marquee-section">
    <div class="marquee-track">
        {%- for i in (1..2) -%}
        <span>{{ section.settings.text_1 | default: 'Frete Grátis acima de R$ 299' }}</span>
        <span>{{ section.settings.text_2 | default: 'Garantia de 2 anos' }}</span>
        <span>{{ section.settings.text_3 | default: 'Troca em até 30 dias' }}</span>
        <span>{{ section.settings.text_4 | default: 'Pagamento em até 12x' }}</span>
        <span>{{ section.settings.text_5 | default: 'Entrega para todo Brasil' }}</span>
        <span>{{ section.settings.text_6 | default: 'Suporte 24/7' }}</span>
        {%- endfor -%}
    </div>
</div>

{% schema %}
{
    "name": "Marquee Banner",
    "settings": [
        { "type": "text", "id": "text_1", "label": "Texto 1", "default": "Frete Grátis acima de R$ 299" },
        { "type": "text", "id": "text_2", "label": "Texto 2", "default": "Garantia de 2 anos" },
        { "type": "text", "id": "text_3", "label": "Texto 3", "default": "Troca em até 30 dias" },
        { "type": "text", "id": "text_4", "label": "Texto 4", "default": "Pagamento em até 12x" },
        { "type": "text", "id": "text_5", "label": "Texto 5", "default": "Entrega para todo Brasil" },
        { "type": "text", "id": "text_6", "label": "Texto 6", "default": "Suporte 24/7" }
    ],
    "presets": [{ "name": "Marquee Banner" }]
}
{% endschema %}
