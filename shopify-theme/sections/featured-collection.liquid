<!-- ======== FEATURED COLLECTION / PRODUCT GRID ======== -->
<section class="section" id="products">
    <div class="container">
        <div class="section-header">
            <span class="tag">Loja</span>
            <h2>{{ section.settings.title | default: 'Destaques da Semana' }}</h2>
            <p>{{ section.settings.subtitle | default: 'Produtos selecionados com o selo de qualidade Aurum.' }}</p>
        </div>
        <div class="products-grid" id="products-grid">
            {%- assign collection = collections[section.settings.collection] -%}
            {%- for product in collection.products limit: section.settings.products_to_show -%}
            <article class="product-card">
                <a href="{{ product.url }}">
                    <div class="product-img">
                        {%- if product.featured_image != blank -%}
                        <img src="{{ product.featured_image | image_url: width: 600 }}" 
                             alt="{{ product.featured_image.alt | default: product.title }}" 
                             loading="lazy"
                             width="600" height="600">
                        {%- endif -%}

                        {%- if product.compare_at_price > product.price -%}
                            {%- assign discount = product.compare_at_price | minus: product.price | times: 100 | divided_by: product.compare_at_price -%}
                            <span class="product-tag">-{{ discount }}%</span>
                        {%- elsif product.tags contains 'lancamento' -%}
                            <span class="product-tag">Lançamento</span>
                        {%- elsif product.tags contains 'mais-vendido' -%}
                            <span class="product-tag">Mais Vendido</span>
                        {%- endif -%}

                        <div class="product-actions">
                            <form method="post" action="/cart/add">
                                <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">
                                <input type="hidden" name="quantity" value="1">
                                <button type="submit" aria-label="Adicionar {{ product.title }} ao carrinho">
                                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
                                </button>
                            </form>
                        </div>
                    </div>
                    <div class="product-info">
                        <p class="category">{{ product.type }}</p>
                        <h4>{{ product.title }}</h4>
                        <div class="product-price-row">
                            <span class="product-price">
                                {{ product.price | money }}
                                {%- if product.compare_at_price > product.price -%}
                                <span class="old-price">{{ product.compare_at_price | money }}</span>
                                {%- endif -%}
                            </span>
                        </div>
                    </div>
                </a>
            </article>
            {%- endfor -%}
        </div>
    </div>
</section>

{% schema %}
{
    "name": "Coleção em Destaque",
    "class": "section-featured-collection",
    "settings": [
        {
            "type": "text",
            "id": "title",
            "label": "Título",
            "default": "Destaques da Semana"
        },
        {
            "type": "text",
            "id": "subtitle",
            "label": "Subtítulo",
            "default": "Produtos selecionados com o selo de qualidade Aurum."
        },
        {
            "type": "collection",
            "id": "collection",
            "label": "Coleção de produtos"
        },
        {
            "type": "range",
            "id": "products_to_show",
            "label": "Produtos para exibir",
            "min": 2,
            "max": 12,
            "step": 1,
            "default": 8
        }
    ],
    "presets": [
        {
            "name": "Coleção em Destaque"
        }
    ]
}
{% endschema %}
